# Extended NGC PyTorch 26.03 with MindEye runtime deps baked in.
# Same pattern as Raramuri arm64 build: docker build → apptainer convert.
#
# Why 26.03 (torch 2.11), not 23.10 (paper's torch 2.1.0):
# 23.10 was built before Blackwell — its arch list stops at sm_90 and won't
# launch kernels on GB10 (sm_120/121). For inference on this hardware we
# need 26.03's Blackwell-aware torch even though MedARC's setup.sh pins 2.1.0.
#
# We make the deps compatible with torch 2.11 by tightening the transitive
# pins MedARC's pyproject.toml carries — particularly huggingface-hub<0.26.0
# (which keeps hf_cache_home that diffusers==0.23.0 expects). This is what
# the build-944 cascade was missing.

FROM nvcr.io/nvidia/pytorch:26.03-py3

ENV DEBIAN_FRONTEND=noninteractive

# NGC 26.03 ships Ubuntu 24.04 with PEP-668. Install MindEye deps into a
# venv with --system-site-packages so we keep the Blackwell-tuned torch
# 2.11.0a0+nv26.03 + cuDNN 9.2 + CUDA 13.2 from the base, while having a
# writable layer for the paper's deps.
RUN python -m pip install --no-cache-dir --quiet uv

ENV VENV_DIR=/opt/mindeye_env
RUN uv venv --python "$(which python)" --system-site-packages "$VENV_DIR"
ENV PATH="$VENV_DIR/bin:$PATH"

# Paper pins from MedARC-AI/MindEyeV2/src/setup.sh — adjusted to be
# compatible with torch 2.11 by adding pins MedARC didn't need to make
# explicit (their pyproject.toml had them as transitive resolves):
#   - huggingface-hub<0.26.0 (keeps hf_cache_home for diffusers 0.23)
#   - tokenizers==0.15.2 (matches transformers 4.37.2)
# We DON'T install xformers — its 0.0.22.post7 won't link against torch
# 2.11. SDPA in torch 2.11 is faster than xformers anyway. xformers is
# only used by some optional MindEye attention paths we don't hit during
# retrieval-only inference.
RUN uv pip install --python "$VENV_DIR/bin/python" --no-cache --quiet \
    "matplotlib==3.8.2" \
    "scikit-image==0.22.0" \
    "accelerate==0.24.1" \
    "webdataset==0.2.73" \
    "pandas==2.2.0" \
    einops ftfy regex \
    "kornia==0.7.1" \
    "h5py==3.10.0" \
    "open_clip_torch==2.24.0" \
    "transformers==4.37.2" \
    "tokenizers==0.15.2" \
    "huggingface-hub<0.26.0" \
    "torchmetrics==1.3.0.post0" \
    "diffusers==0.23.0" \
    "omegaconf==2.3.0" \
    "sentence-transformers==2.5.1" \
    "evaluate==0.4.1" \
    nilearn nibabel imageio scipy tqdm

# OpenAI CLIP with --no-deps (per setup.sh).
RUN uv pip install --python "$VENV_DIR/bin/python" --no-cache --quiet --no-deps \
    "git+https://github.com/openai/CLIP.git"

# dalle2-pytorch
RUN uv pip install --python "$VENV_DIR/bin/python" --no-cache --quiet \
    "dalle2-pytorch==1.15.6"

# sgm (Stability generative-models) — copy local source then install.
COPY mindeye_generative_models/ /opt/sgm_src/
RUN uv pip install --python "$VENV_DIR/bin/python" --no-cache --quiet /opt/sgm_src/ || \
    echo "WARN: sgm install failed; sys.modules stub fallback in retrieval script"

# Smoke check at build time. We need TWO things to work:
#   (1) imports resolve (catches dep-version mismatches)
#   (2) CUDA kernels actually launch on the target hardware (catches
#       sm_arch mismatch — e.g., NGC 23.10 was pre-Blackwell, may fall
#       back to CPU on GB10).
# Note: build runs on the same host as deploy (DGX Spark GB10), so
# nvidia-runtime should expose the GPU at build time too.
RUN python -c "\
import torch, open_clip, diffusers, accelerate; \
from diffusers.models.vae import Decoder; \
print(f'torch {torch.__version__} | cuda {torch.version.cuda} | diffusers {diffusers.__version__}'); \
print('imports OK'); \
assert torch.cuda.is_available(), 'CUDA not available at build time'; \
print(f'GPU: {torch.cuda.get_device_name(0)}'); \
print(f'compute capability: sm_{torch.cuda.get_device_capability(0)[0]}{torch.cuda.get_device_capability(0)[1]}'); \
print(f'torch arch list: {torch.cuda.get_arch_list()}'); \
x = torch.randn(64, device='cuda'); y = (x @ x).cpu().item(); \
print(f'cuda matmul OK ({y:.3f}) — kernel actually launched on this GPU')"

LABEL maintainer="Morgan Hough <morgan.hough@gmail.com>"
LABEL source="github.com/m9h/hippy-feat — containers/Dockerfile.mindeye_pytorch"