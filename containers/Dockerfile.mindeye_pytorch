# Extended NGC PyTorch with MindEye runtime deps baked in.
# Same pattern as Raramuri arm64 build: docker build → apptainer convert.
#
# IMPORTANT: base is NGC PyTorch 23.10 (torch 2.1.x), NOT 26.03 (torch 2.11).
# MedARC MindEyeV2/src/setup.sh pins torch==2.1.0; deps like accelerate==0.24.1,
# transformers==4.37.2, diffusers==0.23.0 expect that torch. Using newer torch
# leaks into hf_cache_home / accelerate state_dict / xformers ABI mismatches.
# We trade Blackwell-specific tuning for compatibility with the paper's checkpoint.

FROM nvcr.io/nvidia/pytorch:23.10-py3

ENV DEBIAN_FRONTEND=noninteractive

# NGC 23.10 ships Ubuntu 22.04 (no PEP-668), so we can pip into the
# container's torch 2.1.x environment directly — no venv gymnastics.
# Install line copied verbatim from MedARC-AI/MindEyeV2/src/setup.sh.

RUN pip install --no-cache-dir --upgrade pip

RUN pip install --no-cache-dir \
    numpy "matplotlib==3.8.2" tqdm "scikit-image==0.22.0" \
    "accelerate==0.24.1" "webdataset==0.2.73" "pandas==2.2.0" einops ftfy regex \
    "kornia==0.7.1" "h5py==3.10.0" "open_clip_torch==2.24.0" \
    "transformers==4.37.2" "xformers==0.0.22.post7" \
    "torchmetrics==1.3.0.post0" "diffusers==0.23.0" \
    "omegaconf==2.3.0" "sentence-transformers==2.5.1" \
    "evaluate==0.4.1" nilearn nibabel imageio "scipy"

# OpenAI CLIP with --no-deps (per setup.sh) — prevents pulling regex/ftfy
# at versions that conflict with what we already installed.
RUN pip install --no-cache-dir --no-deps "git+https://github.com/openai/CLIP.git"

# dalle2-pytorch (no version pin per setup.sh; pyproject pinned 1.15.6)
RUN pip install --no-cache-dir "dalle2-pytorch==1.15.6"

# sgm (Stability generative-models) — copy local source then install.
COPY mindeye_generative_models/ /opt/sgm_src/
RUN pip install --no-cache-dir /opt/sgm_src/ || \
    echo "WARN: sgm install failed; sys.modules stub fallback in retrieval script"

# Smoke check at build time so a broken image fails immediately.
RUN python -c "\
import torch, open_clip, diffusers, accelerate; \
from diffusers.models.vae import Decoder; \
print(f'torch {torch.__version__} | cuda {torch.version.cuda} | diffusers {diffusers.__version__}'); \
print('Decoder imported OK')"

LABEL maintainer="Morgan Hough <morgan.hough@gmail.com>"
LABEL source="github.com/m9h/hippy-feat — containers/Dockerfile.mindeye_pytorch"
